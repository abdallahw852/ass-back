# ────────────────────────────────────────────────
#  ASAS OS — Environment Variables
#  Copy this file to .env and fill in real values
# ────────────────────────────────────────────────

# ── Write DB (PostgreSQL Primary) ────────────────
WRITE_DB_HOST=145.241.111.182
WRITE_DB_PORT=5432
WRITE_DB_USER=postgres
WRITE_DB_PASS=postgres
WRITE_DB_NAME=asas_write

# ── Read DB (PostgreSQL Read Replica / Standby) ──
READ_DB_HOST=localhost
READ_DB_PORT=5433
READ_DB_USER=postgres
READ_DB_PASS=postgres
READ_DB_NAME=asas_read

# ── Redis ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300

# ── Elasticsearch ─────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# ── JWT ───────────────────────────────────────────
JWT_SECRET=super-secret-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_ISSUER=asas-os
JWT_AUDIENCE=asas-os-clients

# ── Paymob ────────────────────────────────────────
PAYMOB_SECRET_KEY=
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_ID=
PAYMOB_SUBSCRIPTION_WEBHOOK_URL=
PAYMOB_WEBHOOK_URL=
PAYMOB_NOTIFICATION_URL=
PAYMOB_REDIRECTION_URL=https://www.asas-os.com/
PAYMOB_BASE_URL=https://ksa.paymob.com

# ── Oracle Buckets (OCI Object Storage) ───────────
OCI_REGION=eu-frankfurt-1
OCI_NAMESPACE=your-namespace
OCI_BUCKET=asas-media
OCI_TENANCY=ocid1.tenancy.oc1..
OCI_USER=ocid1.user.oc1..
OCI_FINGERPRINT=00:11:22...
OCI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── Twilio (SMS / WhatsApp) ───────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Firebase (Push Notifications) ─────────────────
FIREBASE_PROJECT_ID=asas-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@...
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── SMTP (Email) ──────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=...
SMTP_FROM="ASAS OS <no-reply@example.com>"

# ── Sessions ───────────────────────────────────────
SESSION_SECRET=replace-with-long-random-string
SESSION_COOKIE_NAME=sid
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=604800

# ── OTP Login ──────────────────────────────────────
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_RESEND_WINDOW_SECONDS=60
OTP_MAX_ATTEMPTS=5

# ── Torod (Platform Shipping) ─────────────────────
TOROD_BASE_URL=https://demo.stage.torod.co/en/api/
TOROD_CLIENT_ID=
TOROD_CLIENT_SECRET=
TOROD_WAREHOUSE_CODE=
TOROD_WAREHOUSE_CITY_ID=
TOROD_DEFAULT_WEIGHT_KG=1

# ── App ───────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3001,http://localhost:5173
